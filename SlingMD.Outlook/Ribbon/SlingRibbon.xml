<?xml version="1.0" encoding="UTF-8"?>
<customUI xmlns="http://schemas.microsoft.com/office/2009/07/customui" onLoad="Ribbon_Load">
  <ribbon>
    <tabs>
      <tab id="SlingTab" label="Sling">
        <group id="SlingGroup" label="Sling">
          <button id="SlingButton"
                  label="Sling"
                  size="large"
                  onAction="OnSlingButtonClick"
                  getImage="GetSlingButtonImage" />
          <button id="CompleteThreadButton"
                  label="Complete Thread"
                  size="large"
                  imageMso="ConversationSettings"
                  onAction="OnCompleteThreadClick"
                  supertip="Find and sling missing emails from the current email's thread"/>
        </group>
        <group id="SettingsGroup" label="Settings">
          <button id="SettingsButton"
                  label="Configure"
                  size="large"
                  imageMso="ControlProperties"
                  onAction="OnSettingsButtonClick" />
        </group>
        <group id="AppointmentsGroup" label="Appointments">
          <button id="SaveTodaysButton"
                  label="Save Today"
                  size="large"
                  imageMso="ShowSchedulingPage"
                  onAction="OnSaveTodaysClick"
                  supertip="Save all of today's appointments to Obsidian"/>
          <button id="SaveDateRangeButton"
                  label="Save Date Range"
                  size="large"
                  imageMso="DateAndTimeInsert"
                  onAction="OnSaveDateRangeClick"
                  supertip="Save appointments for a custom date range to Obsidian"/>
        </group>
        <group id="ContactsGroup" label="Contacts">
          <button id="SlingAllContactsButton"
                  label="Sling All Contacts"
                  size="large"
                  imageMso="DistributionListSelectMembers"
                  onAction="OnSlingAllContactsClick"
                  supertip="Export all contacts from your address book to Obsidian"/>
        </group>
      </tab>
    </tabs>
  </ribbon>
</customUI> 